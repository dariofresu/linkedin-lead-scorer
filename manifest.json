{
  "manifest_version": 3,
  "name": "LinkedIn Lead Scorer",
  "version": "1.2.2",
  "description": "Score LinkedIn connection requests against Avatar A & B criteria. Built for EMC/hardware sales professionals.",
  "permissions": ["sidePanel", "storage", "tabs", "activeTab", "scripting"],
  "host_permissions": [
    "https://www.linkedin.com/*",
    "https://openrouter.ai/*",
    "https://api.groq.com/*",
    "https://generativelanguage.googleapis.com/*",
    "https://api.anthropic.com/*",
    "https://api.github.com/*"
  ],
  "background": { "service_worker": "background.js" },
  "side_panel": { "default_path": "sidepanel.html" },
  "content_scripts": [{
    "matches": ["https://www.linkedin.com/mynetwork/invitation-manager/*"],
    "js": ["content.js"],
    "run_at": "document_idle"
  }],
  "action": { "default_title": "LinkedIn Lead Scorer" },
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  }
}
