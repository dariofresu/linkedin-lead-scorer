{
  "manifest_version": 3,
  "name": "LinkedIn Lead Scorer",
  "version": "1.2.0",
  "description": "Score LinkedIn connection requests against Avatar A & B. For Fresu Electronics.",
  "permissions": ["sidePanel", "storage", "tabs", "activeTab", "scripting"],
  "host_permissions": [
    "https://www.linkedin.com/*",
    "https://openrouter.ai/*",
    "https://api.groq.com/*",
    "https://generativelanguage.googleapis.com/*",
    "https://api.anthropic.com/*",
    "https://api.github.com/*"
  ],
  "background": { "service_worker": "background.js" },
  "side_panel": { "default_path": "sidepanel.html" },
  "content_scripts": [{
    "matches": ["https://www.linkedin.com/mynetwork/invitation-manager/*"],
    "js": ["content.js"],
    "run_at": "document_idle"
  }],
  "action": { "default_title": "LinkedIn Lead Scorer" }
}
